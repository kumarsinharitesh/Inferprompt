# All keys are optional — the Mock provider works without any keys.
# Copy this file to .env.local and fill in your keys.

# Sarvam AI (https://sarvam.ai/)
VITE_SARVAM_API_KEY=

# OpenRouter (https://openrouter.ai/)
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=openai/gpt-4o-mini

# Google Gemini (https://aistudio.google.com/)
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-1.5-flash

# Groq (https://console.groq.com/)
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama3-8b-8192

# Mock provider options
# Set to a number to simulate failure after N tokens (leave empty to disable)
VITE_MOCK_FAIL_AFTER=
# Token delay range in ms: MIN,MAX
VITE_MOCK_DELAY=20,80
